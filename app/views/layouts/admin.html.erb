<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Admin — Blog Sempre Altaneiro" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 text-black min-h-screen" data-controller="admin-sidebar">
    <div class="lg:hidden bg-black text-white px-4 py-3 flex items-center justify-between sticky top-0 z-20">
      <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
        <span class="text-red-600 font-black text-lg leading-none" aria-hidden="true">●</span>
        <span class="font-black text-sm tracking-tight uppercase">Admin</span>
      <% end %>
      <button type="button" data-action="admin-sidebar#toggle"
              class="p-2 -mr-2 bg-transparent border-0 cursor-pointer text-white"
              aria-label="Abrir menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <div class="flex min-h-screen">
      <div data-admin-sidebar-target="backdrop" data-action="click->admin-sidebar#toggle"
           class="hidden fixed inset-0 bg-black/50 z-30 lg:hidden"></div>

      <aside data-admin-sidebar-target="sidebar"
             class="fixed inset-y-0 left-0 z-40 w-64 bg-black text-white flex flex-col
                    transform -translate-x-full transition-transform duration-200 ease-in-out
                    lg:static lg:translate-x-0 lg:w-56 lg:shrink-0">
        <div class="px-5 py-5 border-b border-white/10 flex items-center justify-between">
          <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
            <span class="text-red-600 font-black text-lg leading-none" aria-hidden="true">●</span>
            <span class="font-black text-sm tracking-tight uppercase leading-tight">Blog Sempre<br>Altaneiro</span>
          <% end %>
          <button type="button" data-action="admin-sidebar#toggle"
                  class="lg:hidden p-1 bg-transparent border-0 cursor-pointer text-white/60 hover:text-white"
                  aria-label="Fechar menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18"/>
            </svg>
          </button>
        </div>

        <nav class="flex-1 px-3 py-4 flex flex-col gap-1 text-sm font-medium overflow-y-auto">
          <%= link_to "Posts", admin_posts_path,
                class: "flex items-center gap-2 px-3 py-2 rounded hover:bg-white/10 transition-colors #{controller_name == 'posts' ? 'bg-white/10 text-red-400' : 'text-gray-300'}" %>
          <%= link_to "Categorias", admin_categories_path,
                class: "flex items-center gap-2 px-3 py-2 rounded hover:bg-white/10 transition-colors #{controller_name == 'categories' ? 'bg-white/10 text-red-400' : 'text-gray-300'}" %>
          <%= link_to "Tags", admin_tags_path,
                class: "flex items-center gap-2 px-3 py-2 rounded hover:bg-white/10 transition-colors #{controller_name == 'tags' ? 'bg-white/10 text-red-400' : 'text-gray-300'}" %>
          <%= link_to "Comentários", admin_comments_path,
                class: "flex items-center gap-2 px-3 py-2 rounded hover:bg-white/10 transition-colors #{controller_name == 'comments' ? 'bg-white/10 text-red-400' : 'text-gray-300'}" %>
        </nav>

        <div class="px-3 py-4 border-t border-white/10 text-sm space-y-1">
          <%= link_to root_path,
                class: "flex items-center gap-2 px-3 py-2 rounded text-gray-300 hover:bg-white/10 hover:text-white transition-colors" do %>
            <span aria-hidden="true">←</span>
            <span>Ver site</span>
          <% end %>
          <p class="px-3 text-gray-400 text-xs pt-2 truncate"><%= Current.user&.name %></p>
          <%= button_to "Sair", session_path, method: :delete,
                class: "w-full text-left px-3 py-2 rounded text-gray-300 hover:bg-white/10 hover:text-red-400 transition-colors bg-transparent border-0 cursor-pointer text-sm font-medium" %>
        </div>
      </aside>

      <div class="flex-1 flex flex-col min-w-0">
        <header class="bg-white border-b border-gray-200 px-4 lg:px-8 py-4 flex items-center justify-between gap-3 flex-wrap">
          <h1 class="text-lg font-black"><%= content_for?(:page_title) ? yield(:page_title) : controller_name.capitalize %></h1>
          <% if notice = flash[:notice] %>
            <p class="px-4 py-2 bg-black text-white text-xs font-medium rounded"><%= notice %></p>
          <% end %>
          <% if alert = flash[:alert] %>
            <p class="px-4 py-2 bg-red-600 text-white text-xs font-medium rounded"><%= alert %></p>
          <% end %>
        </header>

        <main class="flex-1 px-4 lg:px-8 py-6 lg:py-8">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
