<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Blog Sempre Altaneiro" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Blog Sempre Altaneiro">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700;1,800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-neutral-100 text-black min-h-screen flex flex-col pt-16" style="font-family: 'Inter', sans-serif;">
    <%= render "shared/navbar" %>

    <%= yield :fullwidth %>

    <main class="flex-1 container mx-auto px-4 py-10 max-w-6xl">
      <% if notice = flash[:notice] %>
        <p class="mb-6 px-4 py-3 bg-black text-white text-sm font-medium"><%= notice %></p>
      <% end %>
      <% if alert = flash[:alert] %>
        <p class="mb-6 px-4 py-3 bg-red-600 text-white text-sm font-medium"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
