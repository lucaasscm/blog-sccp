<% content_for :page_title, "Tags" %>

<div class="flex items-center justify-between mb-6">
  <p class="text-gray-500 text-sm"><%= @tags.length %> tag(s)</p>
  <%= link_to "Nova tag", new_admin_tag_path,
        class: "px-4 py-2 bg-black text-white text-sm font-bold rounded hover:bg-red-600 transition-colors" %>
</div>

<% if @tags.empty? %>
  <div class="text-center py-20 text-gray-400">
    <p class="text-lg font-bold">Nenhuma tag ainda.</p>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
    <table class="w-full text-sm min-w-[480px]">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-5 py-3 font-bold text-gray-600 uppercase text-xs tracking-wider">Título</th>
          <th class="text-left px-5 py-3 font-bold text-gray-600 uppercase text-xs tracking-wider">Posts</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @tags.each do |tag| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3 font-medium">#<%= tag.title %></td>
            <td class="px-5 py-3 text-gray-500"><%= tag.posts_count %></td>
            <td class="px-5 py-3 text-right">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "Editar", edit_admin_tag_path(tag), class: "text-xs font-bold hover:text-red-600 transition-colors" %>
                <%= button_to "Excluir", admin_tag_path(tag), method: :delete,
                      data: { turbo_confirm: "Tem certeza que deseja excluir esta tag?" },
                      class: "text-xs font-bold text-red-600 hover:text-red-800 transition-colors bg-transparent border-0 cursor-pointer" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
