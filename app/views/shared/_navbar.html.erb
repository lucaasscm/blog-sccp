<nav class="site-navbar" data-controller="navbar">
  <div class="container mx-auto px-4 max-w-6xl flex items-center justify-between h-16">
    <%= link_to root_path, class: "flex items-center gap-3 group" do %>
      <div class="w-9 h-9 bg-black flex items-center justify-center flex-shrink-0">
        <span class="text-white font-black text-lg leading-none">C</span>
      </div>
      <div class="flex flex-col leading-none">
        <span class="font-black text-sm tracking-tight uppercase font-serif-display">Blog Sempre Altaneiro</span>
        <span class="text-xs text-gray-500 uppercase tracking-widest mt-0.5">Blog do Timão</span>
      </div>
    <% end %>

    <div class="flex items-center gap-8 text-xs font-semibold tracking-widest uppercase">
      <%= link_to "Home", root_path, class: "text-red-600 hover:text-red-700 transition-colors" %>
      <% if authenticated? %>
        <% if Current.user.admin? || Current.user.author? %>
          <%= link_to "Admin", admin_root_path, class: "text-black hover:text-red-600 transition-colors" %>
        <% end %>
        <%= button_to "Sair", session_path, method: :delete,
              class: "text-black hover:text-red-600 transition-colors bg-transparent border-0 cursor-pointer text-xs font-semibold tracking-widest uppercase p-0" %>
      <% end %>
    </div>
  </div>
</nav>
