<article class="border border-gray-200 rounded-lg overflow-hidden flex flex-col hover:shadow-lg transition-shadow group">
  <% if post.cover_image.attached? %>
    <div class="aspect-video overflow-hidden bg-gray-100">
      <%= image_tag post.cover_image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: post.title %>
    </div>
  <% else %>
    <div class="aspect-video bg-black flex items-center justify-center">
      <span class="text-red-600 text-5xl font-black">●</span>
    </div>
  <% end %>

  <div class="flex flex-col flex-1 p-5">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-bold uppercase tracking-wider bg-black text-white px-2 py-0.5 rounded">
        <%= post.category.title %>
      </span>
      <span class="text-xs text-gray-400">
        <%= post.created_at.strftime("%d/%m/%Y") %>
      </span>
    </div>

    <h2 class="font-black text-xl leading-snug mb-2 group-hover:text-red-600 transition-colors">
      <%= link_to post.title, post_path(post) %>
    </h2>

    <p class="text-gray-600 text-sm leading-relaxed line-clamp-3 flex-1">
      <%= truncate(post.content, length: 140) %>
    </p>

    <div class="mt-4 flex items-center justify-between">
      <% if post.tags.any? %>
        <div class="flex flex-wrap gap-1">
          <% post.tags.first(2).each do |tag| %>
            <span class="text-xs text-gray-500 border border-gray-300 px-2 py-0.5 rounded-full">#<%= tag.title %></span>
          <% end %>
        </div>
      <% else %>
        <span></span>
      <% end %>

      <%= link_to "Ler mais →", post_path(post),
            class: "text-sm font-bold text-red-600 hover:text-red-800 transition-colors" %>
    </div>
  </div>
</article>
