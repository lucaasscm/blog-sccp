<%= link_to post_path(post), class: "group flex flex-col" do %>
  <div class="relative overflow-hidden aspect-video bg-gray-900 mb-4">
    <% fallbacks = %w[post-tactics.jpg post-stadium.jpg post-fan.jpg] %>
    <% if post.cover_image.attached? %>
      <%= image_tag post.cover_image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500", alt: post.title %>
    <% else %>
      <%= image_tag fallbacks[post.id % 3], class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500", alt: post.title %>
    <% end %>
    <div class="absolute top-3 left-3">
      <span class="bg-red-600 text-white text-xs font-bold uppercase tracking-wider px-2 py-1">
        <%= post.category.title %>
      </span>
    </div>
  </div>

  <h2 class="font-serif-display font-bold text-xl leading-snug mb-3 group-hover:text-red-600 transition-colors" style="font-size: 1.2rem; line-height: 1.3;">
    <%= post.title %>
  </h2>

  <p class="text-gray-600 text-sm leading-relaxed line-clamp-2 mb-4 flex-1">
    <%= truncate(post.content, length: 120) %>
  </p>

  <div class="flex items-center gap-2 text-xs text-gray-500 uppercase tracking-wider mt-auto">
    <span><%= post.user.name %></span>
    <span class="text-red-600">●</span>
    <span><%= post.created_at.strftime("%d %b %Y") %></span>
    <% if post.tags.any? %>
      <span class="text-red-600">●</span>
      <span><%= post.tags.first.title %></span>
    <% end %>
  </div>
<% end %>
